# Copy to /etc/proctoring/proctoring.env and fill real values.
# Never commit the filled env file.

# Application paths inside WSL/Linux.
PROCTORING_APP_DIR=/opt/proctoring
PROCTORING_OUTPUT_DIR=/var/lib/proctoring/live
PROCTORING_LIVE_DB=/var/lib/proctoring/live/live_results.sqlite3
PROCTORING_REVIEW_DB=/var/lib/proctoring/review_labels.sqlite3
PROCTORING_CONFIG=/opt/proctoring/config_wsl_live.yaml
PROCTORING_REFERENCE_FACES=/var/lib/proctoring/reference_faces

# Moodle filters. Leave empty to process all, but production should filter.
PROCTORING_COURSE_ID=16
PROCTORING_QUIZ_ID=51

# Moodle dataroot on the remote/Linux host. For the known server this is /var/moodledata.
PROCTORING_MOODLEDATA=/var/moodledata

# Runtime tuning.
PROCTORING_DEVICE=auto
PROCTORING_BATCH_LIMIT=250
PROCTORING_POLL_SECONDS=2
PROCTORING_DASHBOARD_HOST=0.0.0.0
PROCTORING_DASHBOARD_PORT=5001
PROCTORING_DASHBOARD_WORKERS=2

# Moodle PostgreSQL connection.
MOODLE_DB_HOST=127.0.0.1
MOODLE_DB_PORT=5432
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=change-me
MOODLE_DB_PREFIX=mdl_

# Optional SSH bridge. Leave MOODLE_SSH_HOST empty when the DB and moodledata
# are directly reachable from the WSL service.
MOODLE_SSH_HOST=
MOODLE_SSH_PORT=22
MOODLE_SSH_USER=
MOODLE_SSH_PASSWORD=
MOODLE_SSH_KEY_PATH=
MOODLE_SSH_REMOTE_DB_HOST=127.0.0.1
MOODLE_SSH_REMOTE_DB_PORT=5432
MOODLE_SSH_KEEPALIVE_SECONDS=2
MOODLE_SSH_CONNECT_TIMEOUT_SECONDS=15
MOODLE_SSH_CONNECT_RETRIES=8
MOODLE_SSH_CONNECT_RETRY_SLEEP_SECONDS=2
